# Base URL of the Deno Deploy proxy (no trailing slash).
# This file is committed — DO NOT put real secrets here.
# Real local values go in `.env.local` (gitignored).
VITE_API_BASE=http://localhost:8000

# Set to "1" to enable Demo Mode by default (uses cached fixture results,
# bypasses the YouCam API entirely — used for live judging fallback).
VITE_DEMO_MODE=0
